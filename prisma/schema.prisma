// Psychology Assessment Platform — Phase 1 Database
// Run: npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Types (SQLite has no enums; use String)
// ---------------------------------------------------------------------------
// TestType: "rapid" | "deep"
// AgeGroup: "AGE_6_12" | "AGE_13_18" | "AGE_18_25" | "AGE_25_40" | "AGE_40_60" | "AGE_60_PLUS"

// ---------------------------------------------------------------------------
// 1. Categories
// ---------------------------------------------------------------------------

model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  thumbnail   String?
  createdAt   DateTime @default(now()) @map("created_at")

  tests           Test[]
  questions       Question[]
  sessions        TestSession[]
  recommendations TestRecommendation[] @relation("RecommendedCategory")

  @@map("categories")
}

// ---------------------------------------------------------------------------
// Test recommendations (adaptive follow-up: trigger_trait + condition → category)
// ---------------------------------------------------------------------------
// trigger_condition: ">65", "<40" etc. Priority: lower number = higher priority.

model TestRecommendation {
  id                    String   @id @default(cuid())
  triggerTrait          String   @map("trigger_trait")
  triggerCondition      String   @map("trigger_condition")
  recommendedCategoryId String   @map("recommended_category")
  priority              Int      @default(0)

  recommendedCategory Category @relation("RecommendedCategory", fields: [recommendedCategoryId], references: [id], onDelete: Cascade)

  @@map("test_recommendations")
}

// ---------------------------------------------------------------------------
// 2. Tests (per category: rapid vs deep)
// ---------------------------------------------------------------------------

model Test {
  id               String   @id @default(cuid())
  categoryId       String   @map("category_id")
  name             String
  type             String   // "rapid" | "deep"
  durationMinutes  Int      @map("duration_minutes")
  totalQuestions   Int      @map("total_questions")

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, type])
  @@map("tests")
}

// ---------------------------------------------------------------------------
// 3. Question Bank (result-oriented, behavioral, tagged by trait & test type)
// ---------------------------------------------------------------------------
// 4-answer scale: Never=1, Sometimes=2, Often=3, Always=4
// Tagging: category, sub_area, trait_measured, age_group, test_type (rapid/deep)
// Deep: 10 traits × 10 questions = 100. Rapid: 10 traits × 3–4 = 30–40.

model Question {
  id              String   @id @default(cuid())
  categoryId      String   @map("category_id")
  subArea         String?  @map("sub_area")       // e.g. cultural_context, technology, self_awareness
  ageGroup        String   @map("age_group")     // AGE_6_12, AGE_13_18, ...
  questionText    String   @map("question_text")
  traitMeasured   String   @map("trait_measured") // stress, confidence, emotional_stability, etc.
  weight          Int      @default(1)
  culturalContext Boolean  @default(false) @map("cultural_context")
  techContext     Boolean  @default(false) @map("tech_context")
  testType        String   @map("test_type")     // "rapid" | "deep"
  displayOrder    Int?     @map("display_order")  // B2B: fixed order when set; null = randomize
  reverseScored   Boolean  @default(false) @map("reverse_scored") // Always → low trait (e.g. "I doubt my abilities")
  createdAt       DateTime @default(now()) @map("created_at")

  category     Category             @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  answers      Answer[]
  responses    Response[]
  translations QuestionTranslation[]

  @@map("questions")
}

// ---------------------------------------------------------------------------
// 3b. Question translations (Malayalam, Hindi, Tamil, etc.) — rural / regional
// ---------------------------------------------------------------------------
// language_code: e.g. "ml", "hi", "ta" (ISO 639-1)

model QuestionTranslation {
  id             String @id @default(cuid())
  questionId     String @map("question_id")
  languageCode   String @map("language_code")   // ml, hi, ta, ...
  translatedText String @map("translated_text")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, languageCode])
  @@map("question_translations")
}

// ---------------------------------------------------------------------------
// 4. Answers (per question; score_value e.g. Never=1, Always=4)
// ---------------------------------------------------------------------------

model Answer {
  id          String @id @default(cuid())
  questionId  String @map("question_id")
  answerText  String @map("answer_text")
  scoreValue  Int    @map("score_value")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("answers")
}

// ---------------------------------------------------------------------------
// Users (minimal — for session ownership; can extend later)
// ---------------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at")

  sessions        TestSession[]
  careerSessions  CareerSession[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// 5. Test Sessions (user's test run)
// ---------------------------------------------------------------------------

model TestSession {
  id            String    @id @default(cuid())
  userId        String?   @map("user_id")   // nullable for guest
  categoryId    String    @map("category_id")
  testType      String    @map("test_type") // "rapid" | "deep"
  languageCode  String    @default("en") @map("language_code") // en, ml, hi, ta — for loading translated questions
  startedAt     DateTime  @default(now()) @map("started_at")
  completedAt   DateTime? @map("completed_at")
  scoreSummary  String?   @map("score_summary") // JSON string or summary text

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  category Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  responses Response[]
  result   Result?

  @@map("test_sessions")
}

// ---------------------------------------------------------------------------
// 6. Responses (one per question answered in a session)
// ---------------------------------------------------------------------------

model Response {
  id             String   @id @default(cuid())
  sessionId      String   @map("session_id")
  questionId     String   @map("question_id")
  selectedAnswer String   @map("selected_answer") // answer_text or answer id
  score          Int

  session  TestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
  @@map("responses")
}

// ---------------------------------------------------------------------------
// 7. Results (computed after session completion; all 10 traits)
// ---------------------------------------------------------------------------
// trait_scores: JSON object with keys stress, confidence, emotional_stability, etc. (0–100 each)
// Interpretation: see lib/interpretation.ts (e.g. Stress 0–20 Low, 21–35 Moderate, 36–50 High)

model Result {
  id                       String   @id @default(cuid())
  sessionId                String   @unique @map("session_id")
  stressScore              Int      @map("stress_score")       // 0–100 (kept for compatibility)
  confidenceScore          Int      @map("confidence_score")   // 0–100
  emotionalScore           Int      @map("emotional_score")    // 0–100
  traitScores              String?  @map("trait_scores")      // JSON: all 10 traits 0–100
  aiAnalysis               String?  @map("ai_analysis")
  psychologistNotes        String?  @map("psychologist_notes") // B2B counseling workflow
  reviewedByPsychologist   Boolean  @default(false) @map("reviewed_by_psychologist")

  session TestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("results")
}

// ---------------------------------------------------------------------------
// 8. Career Intelligence — full flow: sessions → scores → clusters → recommendations → report
// ---------------------------------------------------------------------------

model CareerSession {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  name       String
  age        Int
  education  String?
  createdAt  DateTime @default(now()) @map("created_at")

  user            User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  scores          CareerScore[]
  recommendations CareerRecommendation[]
  report          CareerReport?

  @@map("career_sessions")
}

model CareerScore {
  id        String @id @default(cuid())
  sessionId String @map("session_id")
  dimension String // cognitive, personality, motivation, emotional, skills, technology, leadership, creativity, work_environment, life_values
  score     Int    // 0–100

  session CareerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, dimension])
  @@map("career_scores")
}

model CareerCluster {
  id            String   @id @default(cuid())
  name          String
  description   String
  exampleRoles  String   @map("example_roles")   // JSON: ["UI/UX Designer", "Product Designer"]
  growthOutlook String   @map("growth_outlook")  // High, Very High, Medium

  recommendations CareerRecommendation[]
  roadmaps        CareerRoadmap[]

  @@map("career_clusters")
}

model CareerRecommendation {
  id        String @id @default(cuid())
  sessionId String @map("session_id")
  clusterId String @map("cluster_id")
  rank      Int    // 1 = top, 2 = second, 3 = third

  session CareerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  cluster CareerCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  @@unique([sessionId, rank])
  @@map("career_recommendations")
}

model CareerRoadmap {
  id          String @id @default(cuid())
  clusterId  String @map("cluster_id")
  step        Int    // 1–5
  title       String
  description String
  skills      String  // JSON array of skill strings

  cluster CareerCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  @@map("career_roadmaps")
}

model CareerReport {
  id              String   @id @default(cuid())
  sessionId       String   @unique @map("session_id")
  aiSummary        String?  @map("ai_summary")
  primaryCluster   String?  @map("primary_cluster") // cluster name for display
  createdAt        DateTime @default(now()) @map("created_at")

  session CareerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("career_reports")
}

// ---------------------------------------------------------------------------
// 8b. MIB Career Intelligence 10D Profiling Engine (separate module)
// ---------------------------------------------------------------------------
// CareerUser: students and parents who can view career results and dashboard.

model CareerUser {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   // "student" | "parent"
  createdAt DateTime @default(now()) @map("created_at")

  sessions         Career10DSession[]
  mentorUsage      MentorUsage[]
  userMissions     UserMission[]
  growth           UserGrowth?
  lifeCoachMessages LifeCoachMessage[]

  @@map("career_users")
}

model MentorUsage {
  id     String @id @default(cuid())
  userId String @map("user_id")
  count  Int    @default(0)
  date   String // YYYY-MM-DD

  user CareerUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("mentor_usage")
}

model Career10DSession {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  userName  String?  @map("user_name")
  userEmail String?  @map("user_email")
  createdAt DateTime @default(now()) @map("created_at")

  user           CareerUser?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  scores         Career10DScore?
  report         Career10DReport?
  instituteTests InstituteTest[]

  @@map("career_10d_sessions")
}

model Career10DScore {
  id             String @id @default(cuid())
  sessionId      String @unique @map("session_id")
  creativity     Int    @default(0)
  analytical     Int    @default(0)
  leadership     Int    @default(0)
  social         Int    @default(0)
  technology     Int    @default(0)
  entrepreneurial Int  @default(0) @map("entrepreneurial")
  practical      Int    @default(0)
  learning       Int    @default(0)
  risk           Int    @default(0)
  purpose        Int    @default(0)

  session Career10DSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("career_10d_scores")
}

model Career10DReport {
  id                  String   @id @default(cuid())
  sessionId           String   @unique @map("session_id")
  cluster             String
  aiReport            String   @map("ai_report")
  potentialProfile    String?  @map("potential_profile") // JSON
  gapAnalysis         String?  @map("gap_analysis")      // JSON
  careerIndex         Float?   @map("career_index")
  probabilities       String?  @map("probabilities")     // JSON
  reportLocked        Boolean  @default(true) @map("report_locked")
  identityName        String?  @map("identity_name")
  identityDescription String?  @map("identity_description")

  session Career10DSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("career_10d_reports")
}

// ---------------------------------------------------------------------------
// 9. Psychologists (for guidance / counselling booking)
// ---------------------------------------------------------------------------

model Psychologist {
  id                String    @id @default(cuid())
  name              String
  specialization    String
  experienceYears   Int        @map("experience_years")
  languages         String    // comma-separated
  rating            Float     @default(0)
  profilePhoto     String?    @map("profile_photo")
  bio               String?
  consultationFee   Int        @map("consultation_fee") // INR
  availability      String?    // JSON: time slots
  createdAt         DateTime  @default(now()) @map("created_at")

  bookings Booking[]

  @@map("psychologists")
}

// ---------------------------------------------------------------------------
// 10. Referral partners (schools, counsellors — earn commission from career tests)
// ---------------------------------------------------------------------------

model ReferralPartner {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?
  organization String?
  commission   Int      @default(30) // percent
  createdAt    DateTime @default(now()) @map("created_at")

  referrals Referral[]

  @@map("referral_partners")
}

model Referral {
  id            String   @id @default(cuid())
  partnerId     String   @map("partner_id")
  studentEmail  String   @map("student_email")
  testType      String   @map("test_type")
  amount        Int      // in INR
  commission    Int      // in INR
  createdAt     DateTime @default(now()) @map("created_at")

  partner ReferralPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("referrals")
}

// ---------------------------------------------------------------------------
// 11. Institutes (schools, coaching centres — bulk students & tests)
// ---------------------------------------------------------------------------

model Institute {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  address   String?
  createdAt DateTime @default(now()) @map("created_at")

  students         InstituteStudent[]
  tests            InstituteTest[]
  analytics        InstituteAnalytics[]
  reports          InstituteReport[]

  @@map("institutes")
}

model InstituteAnalytics {
  id             String   @id @default(cuid())
  instituteId    String   @map("institute_id")
  totalStudents  Int      @map("total_students")
  activeTrainees Int      @map("active_trainees")
  avgReadiness   Float    @map("avg_readiness")
  createdAt      DateTime @default(now()) @map("created_at")

  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@map("institute_analytics")
}

model StudentPerformance {
  id         String   @id @default(cuid())
  studentId  String   @map("student_id")
  examId     String   @map("exam_id")
  readiness  Float
  accuracy   Float
  speed      Float
  weakTopics String   @map("weak_topics") // JSON string
  createdAt  DateTime @default(now()) @map("created_at")

  student InstituteStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exam    Exam             @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@map("student_performance")
}

model InstituteReport {
  id          String   @id @default(cuid())
  instituteId String   @map("institute_id")
  reportData  String   @map("report_data") // JSON string
  createdAt   DateTime @default(now()) @map("created_at")

  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@map("institute_reports")
}

model InstituteStudent {
  id         String   @id @default(cuid())
  instituteId String  @map("institute_id")
  name       String
  email      String?
  age        Int?
  createdAt  DateTime @default(now()) @map("created_at")

  institute   Institute           @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  tests       InstituteTest[]
  performance StudentPerformance[]

  @@map("institute_students")
}

model InstituteTest {
  id         String   @id @default(cuid())
  instituteId String  @map("institute_id")
  studentId  String   @map("student_id")
  sessionId  String?  @map("session_id") // Career10DSession id after test completed
  createdAt  DateTime @default(now()) @map("created_at")

  institute Institute        @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  student   InstituteStudent  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session   Career10DSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@map("institute_tests")
}

// ---------------------------------------------------------------------------
// 12. Bookings (counselling requests)
// ---------------------------------------------------------------------------

model Booking {
  id             String   @id @default(cuid())
  sessionId      String?  @map("session_id")   // optional, if coming from result page
  psychologistId String   @map("psychologist_id")
  userName       String   @map("user_name")
  userEmail      String   @map("user_email")
  status         String   @default("pending")  // pending, confirmed, cancelled
  createdAt      DateTime @default(now()) @map("created_at")

  psychologist Psychologist @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@map("bookings")
}

// ---------------------------------------------------------------------------
// 13. Gamified psychological growth (missions, streaks, levels)
// ---------------------------------------------------------------------------

model GrowthMission {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  points      Int
  createdAt   DateTime @default(now()) @map("created_at")

  userMissions UserMission[]

  @@map("growth_missions")
}

model UserMission {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  missionId   String    @map("mission_id")
  completed   Boolean   @default(false)
  completedAt DateTime? @map("completed_at")

  user   CareerUser     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission GrowthMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@map("user_missions")
}

model UserGrowth {
  id        String    @id @default(cuid())
  userId    String    @unique @map("user_id")
  points    Int       @default(0)
  level     Int       @default(1)
  streak    Int       @default(0)
  lastActive DateTime? @map("last_active")

  user CareerUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_growth")
}

// ---------------------------------------------------------------------------
// 14. AI Life Coach (daily guidance + habit suggestions)
// ---------------------------------------------------------------------------

model LifeCoachMessage {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  message   String
  habits    String?  // JSON array of 3 habit strings
  date      String   // YYYY-MM-DD
  createdAt DateTime @default(now()) @map("created_at")

  user CareerUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("life_coach_messages")
}

// ---------------------------------------------------------------------------
// 15. Exam Coaching Arena — competitive exam training
// ---------------------------------------------------------------------------

model ExamCategory {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  exams Exam[]

  @@map("exam_categories")
}

model Exam {
  id              String   @id @default(cuid())
  categoryId      String   @map("category_id")
  name            String
  description     String?
  difficulty      String?
  duration        Int?
  totalQuestions  Int?     @map("total_questions")
  createdAt       DateTime @default(now()) @map("created_at")

  category         ExamCategory     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subjects         ExamSubject[]
  questions        ExamQuestion[]
  diagnosticTests  DiagnosticTest[]
  trainingSessions TrainingSession[]
  performanceLogs  PerformanceLog[]
  trainingPlans    TrainingPlan[]
  examReadinesses  ExamReadiness[]
  dailyMissions    DailyTrainingMission[]
  studentPerformances StudentPerformance[]

  @@map("exams")
}

model ExamSubject {
  id        String   @id @default(cuid())
  examId    String   @map("exam_id")
  name      String
  weightage Int?

  exam   Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  topics ExamTopic[]
  questions ExamQuestion[]

  @@map("exam_subjects")
}

model ExamTopic {
  id         String   @id @default(cuid())
  subjectId  String   @map("subject_id")
  name       String
  difficulty String?

  subject   ExamSubject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questions ExamQuestion[]

  @@map("exam_topics")
}

model ExamQuestion {
  id           String   @id @default(cuid())
  examId       String   @map("exam_id")
  subjectId    String   @map("subject_id")
  topicId      String   @map("topic_id")
  questionText String  @map("question_text")
  difficulty   String?
  questionType String  @map("question_type")
  createdAt    DateTime @default(now()) @map("created_at")

  exam    Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject ExamSubject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topic   ExamTopic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@map("exam_questions")
}

model DiagnosticTest {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  examId    String   @map("exam_id")
  score     Int?
  accuracy  Float?
  speed     Float?
  createdAt DateTime @default(now()) @map("created_at")

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@map("diagnostic_tests")
}

model TrainingSession {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  examId      String   @map("exam_id")
  sessionType String   @map("session_type")
  score       Int?
  accuracy    Float?
  duration    Int?
  createdAt   DateTime @default(now()) @map("created_at")

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@map("training_sessions")
}

model PerformanceLog {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  examId      String   @map("exam_id")
  accuracy    Float
  speed       Float
  consistency Float
  weakTopics  String   @map("weak_topics") // JSON string
  createdAt   DateTime @default(now()) @map("created_at")

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@map("performance_logs")
}

model TrainingPlan {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  examId    String   @map("exam_id")
  planData  String   @map("plan_data") // JSON string
  createdAt DateTime @default(now()) @map("created_at")

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@map("training_plans")
}

model ExamReadiness {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  examId         String   @map("exam_id")
  readinessScore Float    @map("readiness_score")
  predictedRank  String?  @map("predicted_rank")
  createdAt      DateTime @default(now()) @map("created_at")

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@map("exam_readiness")
}

model DailyTrainingMission {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  examId      String   @map("exam_id")
  missionData String   @map("mission_data") // JSON
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@map("daily_training_missions")
}
